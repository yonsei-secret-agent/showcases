# API keys. Copy this file to .env and fill keys locally.
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Primary backend for the first smoke run.
MODEL_BACKEND=openrouter

# Who&When-aligned generation defaults.
GENERATION_MODEL=openai/gpt-4o-mini-2024-07-18
CARD_MODEL=openai/gpt-4o
JUDGE_MODEL=openai/gpt-4o
ATTRIBUTION_MODEL=openai/gpt-4o

# API endpoints.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter routing controls. Keep deterministic for experiments.
OPENROUTER_PROVIDER_ORDER=OpenAI
OPENROUTER_ALLOW_FALLBACKS=false

# Optional OpenRouter attribution headers.
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=WhoWhen Card PoC

# Experiment controls.
EXPERIMENT_SEED=20260626
GENERATION_TEMPERATURE=0.2
RECURRENCE_TEMPERATURE=0.7
JUDGE_TEMPERATURE=0.0
CARD_TEMPERATURE=0.0
MAX_OUTPUT_TOKENS=1200

# Local paths.
WHO_WHEN_REPO_PATH=third_party/Agents_Failure_Attribution
DATA_DIR=data
REPORTS_DIR=reports
